# ── Required ───────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=1234567890:ABCdef_your_token_here
TELEGRAM_CHAT_ID=123456789
OPENROUTER_API_KEY=or-your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Alternative: Groq (free, faster, more generous limits than OpenRouter free tier)
# Sign up at console.groq.com → API Keys → Create key
# If GROQ_API_KEY is set, it takes priority over OpenRouter for LLM scoring.
# Recommended model: llama-3.3-70b-versatile  (set in OPENROUTER_MODEL below, same field)
# GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Healthchecks.io or similar — GET-pinged on start/end/fail
HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
